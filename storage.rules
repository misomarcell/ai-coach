rules_version = '2';

service firebase.storage {
	match /b/{bucket}/o {
		match /calorie-vision/{userId}/{filename} {
			allow read: if request.auth != null && request.auth.uid == userId;

			allow write: if request.auth != null
				&& request.auth.uid == userId
				&& (resource == null || resource.size < 10 * 1024 * 1024) // Optional: 10MB limit
					&& request.resource.contentType.matches('image/(jpeg|png|gif|webp)');
		}

		match /product-images/{userId}/{foodId}/{filename} {
				allow read: if request.auth != null && request.auth.uid == userId;

				allow write: if request.auth != null
					&& request.auth.uid == userId
					&& (resource == null || resource.size < 10 * 1024 * 1024) // Optional: 10MB limit
						&& request.resource.contentType.matches('image/(jpeg|png|gif|webp)');
		}

		match /cronometer-exports/{userId}/{filename} {
			allow read: if false;

			allow write: if request.auth != null
				&& request.auth.uid == userId
				&& (resource == null || resource.size < 1 * 1024 * 1024) // 1MB limit
					&& request.resource.contentType.matches('text/csv');
		}


		match /{allPaths=**} {
			allow read, write: if isAdmin();
		}
	}
}

function isAdmin() {
	return request.auth != null
		&& request.auth.token.admin == true;
}
