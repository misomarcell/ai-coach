{
	"name": "functions",
	"scripts": {
		"lint": "eslint --ext .js,.ts .",
		"build": "tsc",
		"build:watch": "tsc --watch",
		"serve": "npm run build && firebase emulators:start --only auth,firestore,functions,storage",
		"shell": "npm run build && firebase functions:shell",
		"start": "npm run shell",
		"deploy": "firebase deploy --only functions",
		"logs": "firebase functions:log"
	},
	"engines": {
		"node": "22"
	},
	"main": "lib/index.js",
	"dependencies": {
		"@aicoach/shared": "file:dist/shared",
